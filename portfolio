<script>
const TILE_COLORS = ["#D14B3F","#D99A4E","#A8281F","#E8866F"];

const CASE_STUDIES = [
  {
    id: "line-automation",
    num: "01",
    title: "LINE Communication & Workflow Automation",
    type: "Learning Operations",
    loc: "Japan",
    summary: "A 9-step email loop for scheduling makeup lessons now runs through LINE and resolves in under a minute.",
    steps: [
      { label:"01 — Problem", title:"Nine steps, all done by hand", body:"At KANA English School, every absence or makeup request went through the same email chain: check the site, email a request, wait for staff to check availability, wait again for a teacher consult, get a confirmation, confirm back, and hope someone records it correctly. About 35 of these came in per week across 150 students and 100+ families. On a normal weekday that loop ate up 20+ hours; over a weekend, closer to 30, since the school was closed Sundays. Only staff with strong Japanese could even handle the requests, and because different part-timers picked up different threads, the same conversation would get answered twice or dropped entirely.", reverse:false },
      { label:"02 — Process", title:"Stop fighting the channel parents already use", body:"A survey of parents found 74 of them wanted LINE instead of email, and 43 said the makeup process itself was confusing. So instead of building a separate scheduling app, I built the whole flow inside LINE using LIFF, which lets a custom interface open right inside the chat — no download, no new login. Make.com handles everything behind it: checking a student's identity, pulling live class capacity, preventing two parents from grabbing the same open seat, and even managing credit balances for adult students who pay per lesson.", reverse:true },
      { label:"03 — Outcome", title:"Days down to under a minute", body:"About 70% of parents signed up within the first two weeks. The part that used to take a staff member 10 minutes of manually cross-checking schedules now finishes in under three seconds, and a parent can submit a request, get confirmation, and be done in under a minute total. Staff time went back to the things that actually need a person — not schedule lookups.", reverse:false }
    ]
  },
  {
    id: "churn-study",
    num: "02",
    title: "Parent Retention & Customer Education",
    type: "Customer Education",
    loc: "Japan",
    summary: "Parents thought their kids weren't learning English. The kids were — just not where anyone could see it.",
    steps: [
      { label:"01 — Problem", title:"The progress was real. Parents just couldn't see it.", body:"After more than 30 parent interviews, a pattern showed up everywhere: kids spoke English at school and reverted to their home language the second they walked in the door, because that's just where their identity as a kid lived. To a parent watching from outside, that looked like zero progress, even though teachers were marking most students as on track. Thirteen of 36 parents brought up some version of the same complaint, almost word for word: their kid couldn't even tell them what happened in class that day.", reverse:false },
      { label:"02 — Process", title:"Give the work somewhere to live outside the classroom", body:"Three things came out of this. First, an \"Output Relay\" where students teach the lesson back to a parent at home — turns the kid into the expert instead of the passive recipient, and it had 89% participation in week one. Second, short video explainers in the parent's native language sitting right next to the homework, so a parent who doesn't speak English can still actually help. Third, a flexible observation option — in person or over Google Meet — replacing a single rigid observation week that most working parents couldn't make anyway.", reverse:true },
      { label:"03 — Outcome", title:"Fewer complaints, more parents showing up", body:"Since the Output Relay started, there hasn't been a single complaint about a kid forgetting what happened in class. Homework completion went up 30%, and the listening sections — previously the part everyone just skipped — jumped 45%. Observation attendance nearly tripled, from roughly 20-25 parents a year to 43 in the first cycle alone, close to a third of the whole school.", reverse:false },
      { label:"04 — What's next", title:"From retention to growth", body:"With the trust gap closing, the focus shifted from stopping churn to actively growing enrollment. A targeted marketing push added 25 net-new students in 3 months, and the school is on track for roughly 1.5x total enrollment — about 60 additional students — by next April.", reverse:true }
    ]
  },
  {
    id: "kana-progress-tracking",
    num: "03",
    title: "Student Progress Tracking System",
    type: "Learning Operations",
    loc: "Japan",
    summary: "A logging tool for teachers that had to survive three rebuilds before it actually got used.",
    steps: [
      { label:"01 — Problem", title:"Everyone had an opinion. Nobody had data.", body:"Teachers and parents disagreed constantly about how a student was doing, and there was nothing written down to settle it either way. The real constraint, the one that shaped everything after: teachers get about 8 minutes between classes, and that time is already spoken for — talking to parents on the way out, resetting the room, greeting whoever's coming in next. Anything that asked for more than a minute or two just wasn't going to get used, no matter how good the idea was.", reverse:false },
      { label:"02 — Process", title:"Two failed versions before this one stuck", body:"The first attempt was a Google Sheet with dropdown menus — fine on paper, miserable on a phone, and teachers hated scrolling through it. The second was a proper web app with charts, which was better, but teachers still had to go find the day's class manually, and once the novelty wore off, usage quietly dropped. The version that finally worked uses a QR code at each station that opens straight into whatever class is happening right now, detected automatically by the time. Everything saves to Supabase in real time, and it only asks teachers to log students who stood out — not a full roll call every time.", reverse:true },
      { label:"03 — Outcome", title:"80% adoption, under a minute a class", body:"128 of 160 classes got logged within the first month, an 80% adoption rate, and teachers were spending maybe 5 minutes total across an entire day. The data ended up surfacing something nobody had noticed: engagement consistently dropped for kindergarten classes and for high schoolers, which gave management something concrete to bring into parent conversations instead of relying on whoever happened to remember what.", reverse:false }
    ]
  },
  {
    id: "lifehack-curriculum",
    num: "04",
    title: "Lifehack: Financial Literacy Curriculum",
    type: "Instructional Design",
    loc: "Japan",
    summary: "A trading game built around how Japanese teenagers actually behave in a group, instead of fighting it.",
    steps: [
      { label:"01 — Problem", title:"Built by finance people, for teenagers who tune out fast", body:"Most financial literacy material in Japan gets written by people with finance or policy backgrounds, not teaching backgrounds, and it shows — dense, jargon-heavy, and easy to disengage from. On top of that, instructors tend to either overcorrect for Japanese students' reluctance to speak up in public, or ignore it completely and put kids on the spot, and both approaches backfire in their own way.", reverse:false },
      { label:"02 — Process", title:"Split the round so nobody can hide and nobody gets singled out", body:"Each round runs five minutes, split into two phases. First, an open market window where students trade individually and quietly, low stakes, no pressure to talk. Then a strategy window where the group has to agree on one trade together before time runs out, which forces a conversation that wouldn't happen on its own. The logic comes from Chi and Wylie's ICAP framework — individual action gets you interactive engagement, the forced group decision gets you constructive engagement — and nobody's ever called out by name in front of the room.", reverse:true },
      { label:"03 — Outcome", title:"Built so any facilitator can run it the same way", body:"The module comes with a full facilitator script: exact lines for a silent group, for one student dominating the conversation, for a group that can't agree before time's up. It also has a 3-tier rubric and an anonymous reflection prompt students answer before the group discussion starts, so the activity doesn't depend on one particularly good facilitator to land.", reverse:false }
    ]
  }
];

function tileHTML(cs, idx){
  const color = TILE_COLORS[idx % TILE_COLORS.length];
  return `
    <div class="tile reveal" data-study="${cs.id}">
      <div class="badge" style="background:${color};">${cs.num}</div>
      <div class="info">
        <h3>${cs.title}</h3>
        <div class="desc">${cs.summary}</div>
        <div class="chips"><span>${cs.type}</span><span>${cs.loc}</span></div>
      </div>
      <div class="go">→</div>
    </div>`;
}
document.getElementById("home-tiles").innerHTML = CASE_STUDIES.map((c,i)=>tileHTML(c,i)).join("");
document.getElementById("work-tiles").innerHTML = CASE_STUDIES.map((c,i)=>tileHTML(c,i)).join("");

function openStudy(id){
  const cs = CASE_STUDIES.find(c=>c.id===id);
  if(!cs) return;
  document.getElementById("study-title").textContent = cs.title;
  document.getElementById("study-tags").innerHTML = `<span>${cs.type}</span><span>${cs.loc}</span>`;
  document.getElementById("study-body").innerHTML = cs.steps.map(s=>`
    <div class="story-block ${s.reverse ? 'reverse':''}">
      <div class="visual" data-zoom="${s.title}">
        <div style="font-size:1.4rem;">⤢</div>
        <div>${s.title} — diagram/photo<br>click to preview</div>
      </div>
      <div class="text">
        <span class="step-label">${s.label}</span>
        <h3>${s.title}</h3>
        <p>${s.body}</p>
      </div>
    </div>
  `).join("");
  showView("study");
  window.scrollTo({top:0});
}

function showView(name){
  document.querySelectorAll(".view").forEach(v=>v.classList.remove("active"));
  document.getElementById("view-"+name).classList.add("active");
  document.querySelectorAll("nav a").forEach(a=>a.classList.remove("active"));
  document.querySelectorAll(`nav a[data-nav="${name}"]`).forEach(a=>a.classList.add("active"));
  document.getElementById("main-nav").classList.remove("open");
  initReveal();
}
document.querySelectorAll("[data-nav]").forEach(el=>{
  el.addEventListener("click", e=>{
    e.preventDefault();
    showView(el.getAttribute("data-nav"));
    window.scrollTo({top:0, behavior:"smooth"});
  });
});
document.body.addEventListener("click", e=>{
  const tile = e.target.closest(".tile");
  if(tile) openStudy(tile.getAttribute("data-study"));
});
document.getElementById("menu-toggle").addEventListener("click", ()=>{
  document.getElementById("main-nav").classList.toggle("open");
});

document.body.addEventListener("click", e=>{
  const v = e.target.closest(".visual");
  if(v){
    document.getElementById("zoom-label").textContent = v.getAttribute("data-zoom") + " — full-size preview placeholder";
    document.getElementById("zoom-modal").classList.add("active");
  } else if(e.target.id === "zoom-modal"){
    document.getElementById("zoom-modal").classList.remove("active");
  }
});

document.body.addEventListener("click", e=>{
  if(e.target.closest("[data-headshot]")){
    if(e.target.closest("[contenteditable]")) return;
    alert("Drop your real photo file here once you have one — replace this placeholder div with an <img> tag pointing to it.");
  }
});

const ruler = document.getElementById("ruler");
window.addEventListener("mousemove", e=>{ ruler.style.top = e.clientY + "px"; });

function initReveal(){
  document.querySelectorAll(".reveal").forEach(el=>{
    const rect = el.getBoundingClientRect();
    if(rect.top < window.innerHeight*0.9) el.classList.add("in");
  });
}
const observer = new IntersectionObserver(entries=>{
  entries.forEach(e=>{ if(e.isIntersecting) e.target.classList.add("in"); });
},{threshold:0.1});
function observeAll(){ document.querySelectorAll(".reveal").forEach(el=>observer.observe(el)); }
observeAll();
initReveal();
</script>

